<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ChipTally" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/chip_red</item>
        <item name="colorPrimaryVariant">@color/chip_red_dark</item>
        <item name="colorOnPrimary">@color/chip_cream</item>
        <item name="colorSecondary">@color/chip_gold</item>
        <item name="colorSecondaryVariant">@color/rail_highlight</item>
        <item name="colorOnSecondary">@color/text_dark</item>
        <item name="android:statusBarColor">@color/rail</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <style name="Theme.ChipTally.Translucent" parent="Theme.ChipTally">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <style name="ThemeOverlay.ChipTally.AlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurface">@color/panel</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="colorPrimary">@color/chip_gold</item>
        <item name="materialAlertDialogTitleTextStyle">@style/ChipTally.AlertDialog.Title</item>
    </style>

    <style name="ChipTally.AlertDialog.Title" parent="MaterialAlertDialog.Material3.Title.Text">
        <item name="android:textColor">@color/chip_gold</item>
    </style>
</resources>
